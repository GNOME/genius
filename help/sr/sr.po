#, no-wrap
msgid ""
"function f() = (\n"
"  k := 5;\n"
"  function r(x) [k] = (x+k);\n"
"  k := 10;\n"
"  r\n"
")\n"
msgstr ""
"function f() = (\n"
"  k := 5;\n"
"  function r(x) [k] = (x+k);\n"
