msgstr "<userinput>a^b</userinput>"

#. (itstool) path: listitem/para
#: C/genius.xml:1327
msgid "Exponentiation, raises <varname>a</varname> to the <varname>b</varname>th power."
msgstr "Степеновање, подиже <varname>a</varname> на <varname>b</varname>-ти степен."

