msgstr "Комплекс сандарды модуль бойынша кері айналдыру мүмкін емес"

#: ../src/mpwrap.c:4070
msgid "Can't GCD complex numbers"
msgstr "Комплекс сандардың ЕҮОБ-ін алу мүмкін емес"

#: ../src/mpwrap.c:4099
msgid "Can't LCM complex numbers"
msgstr "Комплекс сандардың ЕКЕС-ін алу мүмкін емес"

#: ../src/mpwrap.c:4116
msgid "Can't get Jacobi symbols of complex numbers"
msgstr "Комплекс сандардың Якоби символдардын алу мүмкін емес"

#: ../src/mpwrap.c:4133
msgid "Can't get Legendre symbols of complex numbers"
msgstr "Комплекс сандардың Лежандр символдардын алу мүмкін емес"

#: ../src/mpwrap.c:4150
msgid "Can't get Jacobi symbol with Kronecker extension for complex numbers"
msgstr "Комплекс сандар үшін Кронекер кеңейтімімен Якоби символын алу мүмкін емес"

#: ../src/mpwrap.c:4167
msgid "Can't get Lucas number for complex numbers"
msgstr "Комплекс сандар үшін Люка санын алу мүмкін емес"

#: ../src/mpwrap.c:4183
msgid "Can't get next prime for complex numbers"
msgstr "Комплекс сандар үшін келесі жай санды алу мүмкін емес"

#: ../src/mpwrap.c:4193 ../src/mpwrap.c:4205 ../src/mpwrap.c:4217 ../src/mpwrap.c:4229
#, c-format
msgid "%s: can't work on complex numbers"
msgstr "%s: комплекс сандарда жұмыс істей алмайды"

#: ../src/mpwrap.c:4458 ../src/mpwrap.c:4536 ../src/mpwrap.c:4601
#, c-format
