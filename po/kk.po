msgstr "Екі көпмүшені (вектор ретінде) алу"

#: ../src/funclib.c:7378
msgid "Multiply two polynomials (as vectors)"
msgstr "Екі көпмүшені (вектор ретінде) көбейту"

#: ../src/funclib.c:7379
