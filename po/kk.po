msgstr "Ағымдағы модульді функциядан тыс контекстен алу"

#: ../src/funclib.c:7406
msgid "Check if a variable or function is defined"
msgstr "Айнымалының немесе функцияның анықталғанын тексеру"

#: ../src/funclib.c:7407
msgid "Undefine a variable (including all locals and globals of the same name)"
msgstr ""
"Айнымалыны анықтамау (соның ішінде бірдей аттағы барлық жергілікті және глобалды "
"айнымалылар)"

#: ../src/funclib.c:7409
msgid ""
"Undefine all unprotected (user defined) global variables and parameters.  Does not "
"reset or change protected (system) parameters."
msgstr ""
