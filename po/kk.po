#: ../src/mpwrap.c:1725 ../src/mpwrap.c:1765
msgid "Can't do factorials of rationals or floats!"
msgstr ""
"Рационал немесе қалқымалы нүктелі сандардың факториалдарын есептеу мүмкін емес!"

#: ../src/mpwrap.c:1731 ../src/mpwrap.c:1771
