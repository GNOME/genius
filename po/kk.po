msgstr "Аргумент логикалық (және сан емес) екенін тексеру"

#: ../src/funclib.c:7358
msgid "Check if argument is a text string"
msgstr "Аргумент мәтіндік жол екенін тексеру"

#: ../src/funclib.c:7359
msgid "Check if argument is a matrix"
msgstr "Аргумент матрица екенін тексеру"

#: ../src/funclib.c:7360
msgid "Check if argument is a function"
msgstr "Аргумент функция екенін тексеру"

#: ../src/funclib.c:7361
