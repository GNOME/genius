#: ../src/funclib.c:7347
msgid "Check if a number or a matrix is all zeros"
msgstr "Сан немесе матрица толығымен нөлдер екенін тексеру"

#: ../src/funclib.c:7348
msgid "Check if a number or a matrix is 1 or identity respectively"
msgstr "Сан немесе матрица сәйкесінше 1 немесе бірлік екенін тексеру"

#: ../src/funclib.c:7350
msgid ""
"Returns true if the element x is in the set X (where X is a vector pretending to be "
"a set)"
msgstr ""
"x элементі X жиынында болса ақиқат қайтарады (мұнда X жиын ретінде көрінетін вектор)"

#: ../src/funclib.c:7351
msgid "Returns true if X is a subset of Y"
msgstr "Егер X Y-тің ішкі жиыны болса ақиқат қайтарады"

#: ../src/funclib.c:7352
msgid ""
"Returns a set theoretic difference X-Y (X and Y are vectors pretending to be sets)"
msgstr ""
"Жиынтық-теориялық X-Y айырмасын қайтарады (X және Y — жиын ретінде көрінетін "
"векторлар)"

#: ../src/funclib.c:7353
msgid ""
"Returns a set theoretic intersection of X and Y (X and Y are vectors pretending to "
"be sets)"
msgstr ""
"X және Y жиынтық-теориялық қиылысуын қайтарады (X және Y — жиын ретінде көрінетін "
"векторлар)"

#: ../src/funclib.c:7355
msgid "Check if argument is a null"
msgstr "Аргумент null екенін тексеру"

#: ../src/funclib.c:7356
