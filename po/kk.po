#: ../src/mpwrap.c:1502
msgid "Can't do GCD of floats or rationals!"
msgstr "Қалқымалы нүктелі немесе рационал сандардың ЕҮОБ-ін алу мүмкін емес!"

#: ../src/mpwrap.c:1529
msgid "Can't modulo invert non integers!"
msgstr "Бүтін емес сандарды модуль бойынша кері айналдыру мүмкін емес!"

