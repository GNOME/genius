msgstr "Аргумент функцияға сілтеме екенін тексеру"

#: ../src/funclib.c:7364
msgid "Check if argument is a complex (non-real) number"
msgstr "Аргумент комплекс (нақты емес) сан екенін тексеру"

#: ../src/funclib.c:7365
msgid "Check if argument is a real number"
msgstr "Аргумент нақты сан екенін тексеру"

#: ../src/funclib.c:7366
