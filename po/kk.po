#: ../src/mpwrap.c:4978
msgid "Can't make random integer out of a complex number"
msgstr "Комплекс саннан кездейсоқ бүтін сан жасау мүмкін емес"

#: ../src/mpwrap.c:5140 ../src/mpwrap.c:5157
msgid "Can't make factorials of complex numbers"
msgstr "Комплекс сандардың факториалдарын есептеу мүмкін емес"

#: ../src/mpwrap.c:5174
msgid "Can't make binomials of complex numbers"
msgstr "Комплекс сандардың биномдық коэффициенттерін есептеу мүмкін емес"

#: ../src/mpwrap.c:5552 ../src/mpwrap.c:5563 ../src/mpwrap.c:5574
msgid "Can't determine type of a complex number"
msgstr "Комплекс санның түрін анықтау мүмкін емес"

#: ../src/mpwrap.c:5668 ../src/mpwrap.c:5691
msgid "Can't convert complex number into integer"
msgstr "Комплекс санды бүтін санға түрлендіру мүмкін емес"

#: ../src/mpwrap.c:5674 ../src/mpwrap.c:5697
