msgstr "Комплекс сандарды салыстыру мүмкін емес"

#: ../src/mpwrap.c:4021
msgid "Can't modulo complex numbers"
msgstr "Комплекс сандарды модульге бөлу мүмкін емес"

#: ../src/mpwrap.c:4044
#, c-format
