#: ../src/mpwrap.c:2488
msgid "Can't make random integer from a non-integer"
msgstr "Бүтін емес саннан кездейсоқ бүтін сан жасау мүмкін емес"

#: ../src/mpwrap.c:2493
msgid "Range for random integer must be positive"
msgstr "Кездейсоқ бүтін сан үшін ауқым оң болуы керек"

#: ../src/mpwrap.c:2679 ../src/mpwrap.c:2707
msgid "Can't get numerator of floating types"
msgstr "Қалқымалы нүктелі түрлердің алымын алу мүмкін емес"

#: ../src/mpwrap.c:2761
msgid "Invalid integer format"
msgstr "Жарамсыз бүтін сан пішімі"

#: ../src/mpwrap.c:2971
