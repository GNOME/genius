msgstr "Вектор көпмүше ретінде пайдалануға жарамды екенін тексеру"

#: ../src/funclib.c:7384
msgid "Make string out of a polynomial (as vector)"
msgstr "Көпмүшеден (вектор ретінде) жол жасау"

#: ../src/funclib.c:7385
msgid "Make function out of a polynomial (as vector)"
msgstr "Көпмүшеден (вектор ретінде) функция жасау"

