msgstr "Аргумент теріс емес нақты бүтін сан екенін тексеру"

#: ../src/funclib.c:7370
msgid "Check if argument is a possibly complex integer"
msgstr "Аргумент комплекс болуы мүмкін бүтін сан екенін тексеру"

#: ../src/funclib.c:7372
msgid "Check if argument is a rational number (non-complex)"
msgstr "Аргумент рационал сан (комплекс емес) екенін тексеру"

#: ../src/funclib.c:7373
msgid "Check if argument is a possibly complex rational number"
msgstr "Аргумент комплекс болуы мүмкін рационал сан екенін тексеру"

#: ../src/funclib.c:7374
msgid "Check if argument is a floating point number (non-complex)"
msgstr "Аргумент қалқымалы нүктелі сан (комплекс емес) екенін тексеру"

#: ../src/funclib.c:7376
msgid "Add two polynomials (vectors)"
msgstr "Екі көпмүшені (векторларды) қосу"

#: ../src/funclib.c:7377
