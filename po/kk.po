#: ../src/funclib.c:7389
msgid "Get all combinations of k numbers from 1 to n as a vector of vectors"
msgstr ""
"1-ден n-ге дейінгі k сандардың барлық комбинацияларын векторлар векторы ретінде алу"

#: ../src/funclib.c:7390
msgid ""
"Get combination that would come after v in call to combinations, first combination "
